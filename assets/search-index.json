layout: null
sitemap: false
---
[{% assign first = true %}{% for p in site.pages %}{% if p.url contains "/cases/" and p.name != "index.md" and p.title %}{% unless first %},{% endunless %}{"t":{{ p.title | jsonify }},"u":{{ p.url | relative_url | jsonify }},"c":{{ p.category | default: "" | jsonify }},"d":{{ p.description | default: "" | jsonify }},"g":{{ p.tags | default: empty | join: " " | jsonify }},"x":{{ p.content | strip_html | strip_newlines | truncate: 650 | jsonify }}}{% assign first = false %}{% endif %}{% endfor %}]
